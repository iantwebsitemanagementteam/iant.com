<section
    class="py-24 px-4 bg-background-dark text-white relative overflow-hidden"
>
    <!-- Abstract Decoration -->
    <div
        class="absolute top-0 right-0 w-96 h-96 bg-primary/10 rounded-full blur-[100px] -mr-48 -mt-48"
    >
    </div>
    <div
        class="absolute bottom-0 left-0 w-64 h-64 bg-primary/5 rounded-full blur-[80px] -ml-32 -mb-32"
    >
    </div>
    <div class="max-w-7xl mx-auto relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div>
                <h2 class="text-4xl font-black mb-6">Support Your Community</h2>
                <p class="text-lg text-slate-400 mb-8 leading-relaxed">
                    Your contributions help us maintain the mosque facilities,
                    support educational programs, and provide aid to those in
                    need. Every donation, no matter how small, makes a
                    significant impact.
                </p>
                <div class="space-y-4">
                    <div class="flex items-center gap-4">
                        <svg
                            class="w-6 h-6 text-primary"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                stroke-linecap="round"
                                stroke-linejoin="round"></path>
                        </svg>
                        <span>Secure &amp; Tax-Deductible</span>
                    </div>
                    <div class="flex items-center gap-4">
                        <svg
                            class="w-6 h-6 text-primary"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                stroke-linecap="round"
                                stroke-linejoin="round"></path>
                        </svg>
                        <span>Direct Impact on Local Programs</span>
                    </div>
                    <div class="flex items-center gap-4">
                        <svg
                            class="w-6 h-6 text-primary"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                stroke-linecap="round"
                                stroke-linejoin="round"></path>
                        </svg>
                        <span>Transparent Financial Reporting</span>
                    </div>
                </div>
            </div>
            <div class="bg-white text-slate-900 p-10 rounded-[2rem] shadow-2xl">
                <h3 class="text-2xl font-bold mb-8 text-center">
                    One-time Donation
                </h3>
                <div class="grid grid-cols-3 gap-3 mb-8">
                    <button
                        class="py-3 border-2 border-slate-100 rounded-xl font-bold hover:border-primary hover:text-primary transition-all"
                        >$25</button
                    >
                    <button
                        class="py-3 border-2 border-primary bg-primary/5 rounded-xl font-bold text-primary"
                        >$50</button
                    >
                    <button
                        class="py-3 border-2 border-slate-100 rounded-xl font-bold hover:border-primary hover:text-primary transition-all"
                        >$100</button
                    >
                </div>
                <form class="space-y-4">
                    <div>
                        <label class="block text-sm font-bold mb-2"
                            >Custom Amount ($)</label
                        >
                        <input
                            class="w-full bg-slate-50 border-0 rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary"
                            placeholder="Enter amount"
                            type="number"
                        />
                    </div>
                    <div>
                        <label class="block text-sm font-bold mb-2"
                            >Donation Type</label
                        >
                        <select
                            class="w-full bg-slate-50 border-0 rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary"
                        >
                            <option>General Fund</option>
                            <option>Zakat</option>
                            <option>Sadaqah</option>
                            <option>Education Fund</option>
                        </select>
                    </div>
                    <button
                        class="w-full bg-primary text-background-dark font-black py-4 rounded-xl mt-6 hover:shadow-lg transition-all"
                    >
                        Complete Donation
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>
