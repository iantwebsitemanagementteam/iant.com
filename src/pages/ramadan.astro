---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Imsakiyah from "../components/Imsakiyah.astro";
import Taraweeh from "../components/Taraweeh.astro";
import Last10Nights from "../components/Last10Nights.astro";
import Eid1 from "../components/Eid1.astro";
import Layout from "../layouts/Layout.astro";
import Circle from "../components/Circle.astro";
---

<Layout>
    <Nav />
    <main class="max-w-7xl mx-auto px-2 py-8 space-y-16">
        <!-- Hero Section -->
        <section
            class="relative overflow-hidden rounded-xl h-125 flex items-center justify-center text-center p-6 bg-slate-900"
            data-alt="Serene mosque interior with soft glowing lanterns during Ramadan night"
        >
            <div
                class="absolute inset-0 bg-cover bg-center opacity-60"
                data-alt="Beautiful intricate mosque architecture with ramadan lanterns"
                style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuD_W5nXfe6itNJHNtiuLsuAokM79NS82B4o028MdRjHn-eYlga1BQaOh3IPCPK3P5NJ9L9IhHVWWWrv_6ngTc6MnnxN7OJ8iVy5a3iqS98yb62m5ir6CB6KmpbAZmh1Ii2HvFeSkB-4VzhkB-37a7YqRF8x7Y-q3uomc9F2XH5tZ3Hhymuqe1pFJ7X92XnApEMGbZH9RiLC2s6NuD9TLMjFkYMRPduXfMTRSvj0YjyhgRhbhWLDkh_lckWj3ICi4XoMGl1fYoDGHPSQ');"
            >
            </div>
            <div
                class="absolute inset-0 bg-linear-to-t from-background-dark via-background-dark/40 to-transparent"
            >
            </div>
            <div class="relative z-10 max-w-2xl space-y-6">
                <h1
                    class="text-white text-5xl md:text-7xl font-black leading-tight"
                >
                    Ramadan at <span class="text-primary">IANT</span>
                </h1>
                <p
                    class="text-slate-200 text-lg md:text-xl font-normal max-w-lg mx-auto leading-relaxed"
                >
                    Experience the spiritual journey of the holy month with our
                    vibrant community. Join us for prayers, community iftars,
                    and spiritual growth.
                </p>
                <div class="flex flex-wrap justify-center gap-4">
                    <button
                        class="bg-primary text-background-dark px-8 py-3 rounded-lg font-bold text-lg hover:scale-105 transition-transform"
                    >
                        View Schedule
                    </button>
                    <button
                        class="bg-white/10 backdrop-blur-md text-white border border-white/20 px-8 py-3 rounded-lg font-bold text-lg hover:bg-white/20 transition-all"
                    >
                        Join Community
                    </button>
                </div>
            </div>
        </section>
        <Imsakiyah />
        <Taraweeh />
        <Last10Nights />
        <Eid1 />
        <!-- Zakat & Fitra Section -->
        <section
            class="bg-background-dark text-white rounded-3xl p-8 md:p-12 relative overflow-hidden"
            id="zakat"
        >
            <div
                class="absolute top-0 right-0 w-64 h-64 bg-primary/20 blur-[100px]"
            >
            </div>
            <div class="relative z-10 grid md:grid-cols-2 gap-12 items-center">
                <div class="space-y-6">
                    <h2 class="text-3xl font-bold text-primary">
                        Zakat &amp; Zakat-al-Fitr
                    </h2>
                    <p class="text-slate-300 text-lg">
                        Fulfill your religious obligation and help those in need
                        within our community. All donations are handled with
                        complete transparency and distributed to verified local
                        families.
                    </p>
                    <div class="flex flex-col gap-3">
                        <div class="flex items-center gap-3">
                            <Circle />
                            <span>Zakat-al-Fitr: $15 per person</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <Circle />
                            <span>Sadaqah &amp; General Donations accepted</span
                            >
                        </div>
                    </div>
                </div>
                <div
                    class="bg-white/5 backdrop-blur-lg border border-white/10 rounded-2xl p-6 space-y-4"
                >
                    <h3 class="font-bold text-xl mb-4">Quick Pay</h3>
                    <div class="grid grid-cols-2 gap-3">
                        <button
                            class="bg-white text-background-dark py-3 rounded-xl font-bold flex items-center justify-center gap-2 hover:bg-slate-100"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="24"
                                height="24"
                                viewBox="0 0 16 16"
                                ><path fill="#2d9d56" d="M16 14H2v-1h13V6h1z"
                                ></path><path
                                    fill="#2d9d56"
                                    d="M13 4v7H1V4zm1-1H0v9h14z"></path><path
                                    fill="#2d9d56"
                                    d="M3 6H2v3h1v1h4a2.5 2.5 0 1 1 0-5H3zm8 0V5H7a2.5 2.5 0 1 1 0 5h4V9h1V6z"
                                ></path></svg
                            > Fitra ($15)
                        </button>
                        <button
                            class="bg-white text-background-dark py-3 rounded-xl font-bold flex items-center justify-center gap-2 hover:bg-slate-100"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                ><g
                                    fill="none"
                                    stroke="#2d9d56"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    ><path
                                        d="M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4h-3a2 2 0 0 0 0 4h3a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1"
                                    ></path><path
                                        d="M3 5v14a2 2 0 0 0 2 2h15a1 1 0 0 0 1-1v-4"
                                    ></path></g
                                ></svg
                            > Zakat
                        </button>
                    </div>
                    <button
                        class="w-full bg-primary text-background-dark py-4 rounded-xl font-bold text-lg mt-2 shadow-lg shadow-primary/20"
                    >
                        Custom Donation Amount
                    </button>
                    <p class="text-center text-xs text-slate-400">
                        Secure payments via Stripe and PayPal
                    </p>
                </div>
            </div>
        </section>

        <!-- Parking & Logistics -->
        <section
            class="bg-primary/5 rounded-3xl p-8 border border-primary/10 overflow-hidden"
            id="parking"
        >
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
                <div class="space-y-6">
                    <h2 class="text-3xl font-bold flex items-center gap-3">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="2em"
                            height="2em"
                            viewBox="0 0 48 48"
                            ><path
                                fill="#2d9d56"
                                d="M36.5 2a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2H39v28.75a1.25 1.25 0 1 0 2.5 0V16H44a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zm-4 4.187A6.3 6.3 0 0 0 30.979 6H16.673a6.25 6.25 0 0 0-6.07 4.763L9.81 14H7.25a1.25 1.25 0 1 0 0 2.5h1.948l-.433 1.767A4.25 4.25 0 0 0 6 22.25v17.5A3.25 3.25 0 0 0 9.25 43h3.5A3.25 3.25 0 0 0 16 39.75V36.5h16v3.25A3.25 3.25 0 0 0 35.25 43H37v-2.5h-1.75a.75.75 0 0 1-.75-.75V36.5H37V34H8.5V22.25c0-.966.784-1.75 1.75-1.75H37V18H11.404l1.627-6.642A3.75 3.75 0 0 1 16.673 8.5H30.98c.536 0 1.053.114 1.521.322zM20.25 28a1.25 1.25 0 1 0 0 2.5h7.5a1.25 1.25 0 1 0 0-2.5zM14 28a2 2 0 1 0 0-4a2 2 0 0 0 0 4m22-2a2 2 0 1 1-4 0a2 2 0 0 1 4 0M8.5 39.75V36.5h5v3.25a.75.75 0 0 1-.75.75h-3.5a.75.75 0 0 1-.75-.75"
                            ></path></svg
                        >
                        Parking &amp; Logistics
                    </h2>
                    <div class="space-y-4">
                        <div
                            class="bg-white dark:bg-background-dark p-4 rounded-xl shadow-sm border border-primary/5"
                        >
                            <h4 class="font-bold mb-1">On-Site Parking</h4>
                            <p class="text-sm text-slate-500">
                                Reserved for elders, families with young
                                children, and people with disabilities. Permits
                                required.
                            </p>
                        </div>
                        <div
                            class="bg-white dark:bg-background-dark p-4 rounded-xl shadow-sm border border-primary/5"
                        >
                            <h4 class="font-bold mb-1">
                                Off-Site: Green Street Garage
                            </h4>
                            <p class="text-sm text-slate-500">
                                Free parking after 6:00 PM. 5-minute walk.
                                Shuttle available every 10 mins during Taraweeh.
                            </p>
                        </div>
                        <div
                            class="bg-white dark:bg-background-dark p-4 rounded-xl shadow-sm border border-primary/5"
                        >
                            <h4 class="font-bold mb-1">Street Parking</h4>
                            <p class="text-sm text-slate-500">
                                Please respect our neighbors. Do not block
                                driveways or park on yellow lines.
                            </p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4 pt-4">
                        <button
                            class="bg-background-dark text-white px-6 py-3 rounded-xl font-bold flex items-center gap-2"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="1.5em"
                                height="1.5em"
                                viewBox="0 0 24 24"
                                ><path
                                    fill="#2d9d56"
                                    d="M12 3.515L3.515 12L12 20.485L20.485 12zm.707-2.122l9.9 9.9a1 1 0 0 1 0 1.414l-9.9 9.9a1 1 0 0 1-1.414 0l-9.9-9.9a1 1 0 0 1 0-1.414l9.9-9.9a1 1 0 0 1 1.414 0M13 10V7.5l3.5 3.5l-3.5 3.5V12h-3v3H8v-4a1 1 0 0 1 1-1z"
                                ></path></svg
                            > Navigate to Mosque
                        </button>
                    </div>
                </div>
                <div
                    class="relative rounded-2xl overflow-hidden border-4 border-white dark:border-slate-800 shadow-xl min-h-[300px]"
                    data-location="Chicago"
                    style=""
                >
                    <div
                        class="absolute inset-0 bg-slate-200 dark:bg-slate-700 flex items-center justify-center"
                    >
                        <div class="text-center p-8">
                            <span
                                class="material-symbols-outlined text-slate-400 dark:text-slate-500 text-6xl mb-4"
                                >map</span
                            >
                            <p class="text-slate-500 font-medium">
                                Interactive Map of Mosque &amp; Parking Zones
                            </p>
                        </div>
                    </div>
                    <!-- Map Overlay Placeholder -->
                    <div
                        class="absolute top-4 right-4 bg-white/90 dark:bg-background-dark/90 p-3 rounded-lg backdrop-blur shadow-lg border border-primary/10"
                    >
                        <p
                            class="text-xs font-bold uppercase tracking-widest text-primary mb-1"
                        >
                            Status
                        </p>
                        <p class="text-sm font-medium">Parking 40% Full</p>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>
