                        </div>
                        <div
                            class="absolute bottom-4 left-4 right-4 text-white"
                        >
                            <p
                                class="text-[10px] font-bold uppercase tracking-widest opacity-80"
                            >
                                Treasurer
                            </p>
                            <h5 class="text-lg font-bold">Asif Mahmood</h5>
                        </div>
                    </div>
                </div>

                <!-- Board Member 5 -->
                <div class="space-y-4 group">
                    <div
                        class="aspect-3/4 rounded-2xl overflow-hidden relative shadow-lg"
                    >
                        <img
                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                            data-alt="Senior man with distinguished look, grey hair, outdoor setting with architectural elements in soft focus"
                            src="https://iant.com/wp-content/uploads/2026/01/DSC07517-scaled.jpeg"
                        />
                        <div
                            class="absolute inset-0 bg-linear-to-t from-background-dark via-transparent to-transparent opacity-60"
                        >
                        </div>
                        <div
                            class="absolute bottom-4 left-4 right-4 text-white"
                        >
                            <p
                                class="text-[10px] font-bold uppercase tracking-widest opacity-80"
                            >
                                Board Member
                            </p>
                            <h5 class="text-lg font-bold">Suzie Ahmed</h5>
                        </div>
                    </div>
                </div>

                <!-- Board Member 6 https://iant.com/wp-content/uploads/2025/12/DSC07527-scaled.jpg -->
                <div class="space-y-4 group">
                    <div
                        class="aspect-3/4 rounded-2xl overflow-hidden relative shadow-lg"
                    >
                        <img
                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                            data-alt="Senior man with distinguished look, grey hair, outdoor setting with architectural elements in soft focus"
                            src="https://iant.com/wp-content/uploads/2025/12/DSC07527-scaled.jpg"
                        />
                        <div
                            class="absolute inset-0 bg-linear-to-t from-background-dark via-transparent to-transparent opacity-60"
                        >
                        </div>
                        <div
                            class="absolute bottom-4 left-4 right-4 text-white"
                        >
                            <p
                                class="text-[10px] font-bold uppercase tracking-widest opacity-80"
                            >
                                Board Member
                            </p>
                            <h5 class="text-lg font-bold">
                                Meherrunnessa Poppy
                            </h5>
                        </div>
                    </div>
                </div>

                <!-- Board Member 7 https://iant.com/wp-content/uploads/2025/12/DSC07527-scaled.jpg -->
                <div class="space-y-4 group">
                    <div
                        class="aspect-3/4 rounded-2xl overflow-hidden relative shadow-lg"
                    >
                        <img
                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                            data-alt="Senior man with distinguished look, grey hair, outdoor setting with architectural elements in soft focus"
                            src="https://iant.com/wp-content/uploads/2025/12/DSC07652-1-scaled.jpg"
                        />
                        <div
                            class="absolute inset-0 bg-linear-to-t from-background-dark via-transparent to-transparent opacity-60"
                        >
                        </div>
                        <div
                            class="absolute bottom-4 left-4 right-4 text-white"
                        >
                            <p
                                class="text-[10px] font-bold uppercase tracking-widest opacity-80"
                            >
                                Board Member
                            </p>
                            <h5 class="text-lg font-bold">
                                Abdulrahman Alkadri
                            </h5>
                        </div>
                    </div>
                </div>

                <!-- Board Member 8 https://iant.com/wp-content/uploads/2025/12/DSC07527-scaled.jpg -->
                <div class="space-y-4 group">
                    <div
                        class="aspect-3/4 rounded-2xl overflow-hidden relative shadow-lg"
                    >
                        <img
                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                            data-alt="Senior man with distinguished look, grey hair, outdoor setting with architectural elements in soft focus"
                            src="https://iant.com/wp-content/uploads/2026/02/IMG_1313-scaled.jpg"
                        />
                        <div
                            class="absolute inset-0 bg-linear-to-t from-background-dark via-transparent to-transparent opacity-60"
                        >
                        </div>
                        <div
                            class="absolute bottom-4 left-4 right-4 text-white"
                        >
                            <p
                                class="text-[10px] font-bold uppercase tracking-widest opacity-80"
                            >
                                Board Member
                            </p>
                            <h5 class="text-lg font-bold">
                                Ibrahim Bility
                            </h5>
                        </div>
                    </div>
                </div>

                <!-- Board Member 9 https://iant.com/wp-content/uploads/2025/12/DSC07527-scaled.jpg -->
                <div class="space-y-4 group">
                    <div
                        class="aspect-3/4 rounded-2xl overflow-hidden relative shadow-lg"
                    >
                        <img
                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                            data-alt="Senior man with distinguished look, grey hair, outdoor setting with architectural elements in soft focus"
                            src="https://iant.com/wp-content/uploads/2026/01/IMG_2547-scaled.jpeg"
                        />
                        <div
                            class="absolute inset-0 bg-linear-to-t from-background-dark via-transparent to-transparent opacity-60"
                        >
                        </div>
                        <div
                            class="absolute bottom-4 left-4 right-4 text-white"
                        >
                            <p
                                class="text-[10px] font-bold uppercase tracking-widest opacity-80"
                            >
                                Board Member
                            </p>
                            <h5 class="text-lg font-bold">
                                Omair Siddiqi
                            </h5>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>
