---
import Layout from "../../layouts/Layout.astro";
export const prerender = false;
---

<Layout>
    <div class="min-h-screen bg-background-light dark:bg-background-dark">
        <!-- Header -->
        <header
            class="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 px-6 py-4 flex items-center justify-between"
        >
            <div class="flex items-center gap-3">
                <div class="bg-primary text-background-dark p-2 rounded-lg">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-5 h-5"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <rect x="3" y="3" width="18" height="18" rx="2"
                        ></rect><circle cx="8.5" cy="8.5" r="1.5"></circle>
                        <polyline points="21 15 16 10 5 21"></polyline>
                    </svg>
                </div>
                <h1 class="text-xl font-bold">Media Manager</h1>
            </div>
            <button
                id="btn-open-upload"
                class="bg-primary hover:bg-primary/90 text-background-dark px-4 py-2 rounded-lg font-bold text-sm flex items-center gap-2 transition-all"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                >
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
                    ></path><polyline points="17 8 12 3 7 8"></polyline><line
                        x1="12"
                        y1="3"
                        x2="12"
                        y2="15"></line>
                </svg>
                Upload
            </button>
        </header>

        <!-- Stats bar -->
        <div
            class="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 px-6 py-3 flex gap-8 text-sm"
        >
            <span class="text-slate-500"
                >Images (CF): <strong
                    id="stat-cf"
                    class="text-slate-900 dark:text-white">—</strong
                ></span
            >
            <span class="text-slate-500"
                >Files (R2): <strong
                    id="stat-r2"
                    class="text-slate-900 dark:text-white">—</strong
                ></span
            >
            <span class="text-slate-500"
                >Total size: <strong
                    id="stat-size"
                    class="text-slate-900 dark:text-white">—</strong
                ></span
            >
        </div>

        <!-- Toolbar -->
        <div
            class="px-6 py-4 flex flex-col sm:flex-row gap-3 items-start sm:items-center justify-between"
        >
            <div class="flex gap-2">
                <button
                    data-tab="all"
                    class="tab-btn active px-4 py-1.5 rounded-full text-sm font-semibold bg-primary text-background-dark"
                    >All</button
                >
                <button
                    data-tab="cf-images"
                    class="tab-btn px-4 py-1.5 rounded-full text-sm font-semibold bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-primary/10 hover:text-primary transition-colors"
                    >Images</button
                >
                <button
                    data-tab="r2"
                    class="tab-btn px-4 py-1.5 rounded-full text-sm font-semibold bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-primary/10 hover:text-primary transition-colors"
                    >Files</button
                >
            </div>
            <input
                id="search"
                type="search"
                placeholder="Search by name…"
                class="w-full sm:w-64 px-4 py-2 rounded-lg bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
            />
        </div>

        <!-- Media grid -->
        <div class="px-6 pb-10">
            <div id="loading" class="text-center py-20 text-slate-400">
                Loading media…
            </div>
            <div id="empty" class="hidden text-center py-20 text-slate-400">
                No media found.
            </div>
            <div
                id="grid"
                class="hidden grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4"
            >
            </div>
        </div>
    </div>

    <!-- ── Upload Modal ──────────────────────────────────────────── -->
    <div
        id="upload-modal"
        class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm"
    >
        <div
            class="bg-white dark:bg-slate-900 rounded-2xl shadow-2xl w-full max-w-lg p-8 relative"
        >
            <button
                id="btn-close-upload"
                class="absolute top-4 right-4 text-slate-400 hover:text-slate-700 dark:hover:text-white"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-5 h-5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    ><line x1="18" y1="6" x2="6" y2="18"></line><line
                        x1="6"
                        y1="6"
                        x2="18"
                        y2="18"></line></svg
                >
            </button>
            <h2 class="text-xl font-bold mb-6">Upload Media</h2>
            <form id="upload-form" class="space-y-4">
                <div
                    id="drop-zone"
                    class="border-2 border-dashed border-slate-300 dark:border-slate-600 rounded-xl p-8 text-center cursor-pointer hover:border-primary transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-10 h-10 mx-auto mb-3 text-slate-300 dark:text-slate-600"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                    >
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
                        ></path><polyline points="17 8 12 3 7 8"
                        ></polyline><line x1="12" y1="3" x2="12" y2="15"></line>
                    </svg>
                    <p class="text-slate-500 text-sm">
                        Drag & drop or <span class="text-primary font-semibold"
                            >browse</span
                        >
                    </p>
                    <p class="text-slate-400 text-xs mt-1">
                        Images → Cloudflare Images &nbsp;·&nbsp; Other files →
                        R2
                    </p>
                    <input
                        id="file-input"
                        type="file"
                        class="hidden"
                        multiple
                    />
                </div>
                <div id="upload-file-list" class="space-y-2 hidden"></div>
                <div>
                    <label class="block text-sm font-semibold mb-1"
                        >Display Name <span class="text-slate-400 font-normal"
                            >(optional)</span
                        ></label
                    >
                    <input
                        name="displayName"
                        type="text"
                        placeholder="Friendly name"
                        class="w-full px-3 py-2 rounded-lg bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
                    />
                </div>
                <div>
                    <label class="block text-sm font-semibold mb-1"
                        >Custom Metadata <span
                            class="text-slate-400 font-normal">(JSON)</span
                        ></label
                    >
                    <textarea
                        name="customMetadata"
                        rows="2"
                        placeholder='{"tag": "hero", "alt": "Banner image"}'
                        class="w-full px-3 py-2 rounded-lg bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary"
                    ></textarea>
                </div>
                <div
                    id="upload-status"
                    class="hidden text-sm text-center py-2 rounded-lg"
                >
                </div>
                <button
                    type="submit"
                    id="btn-upload-submit"
                    class="w-full bg-primary text-background-dark font-bold py-3 rounded-xl hover:bg-primary/90 transition-all disabled:opacity-50"
                >
                    Upload
                </button>
            </form>
        </div>
    </div>

    <!-- ── Edit Metadata Modal ───────────────────────────────────── -->
    <div
        id="edit-modal"
        class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm"
    >
        <div
            class="bg-white dark:bg-slate-900 rounded-2xl shadow-2xl w-full max-w-lg p-8 relative max-h-[90vh] overflow-y-auto"
        >
            <button
                id="btn-close-edit"
                class="absolute top-4 right-4 text-slate-400 hover:text-slate-700 dark:hover:text-white"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-5 h-5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    ><line x1="18" y1="6" x2="6" y2="18"></line><line
                        x1="6"
                        y1="6"
                        x2="18"
                        y2="18"></line></svg
                >
            </button>
            <h2 class="text-xl font-bold mb-1">Edit Metadata</h2>
            <p
                id="edit-source-badge"
                class="text-xs font-semibold text-primary mb-6"
            >
            </p>
            <form id="edit-form" class="space-y-4">
                <input type="hidden" id="edit-source" />
                <input type="hidden" id="edit-id" />
                <div>
                    <label class="block text-sm font-semibold mb-1"
                        >Display Name</label
                    >
                    <input
                        id="edit-name"
                        type="text"
                        class="w-full px-3 py-2 rounded-lg bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
                    />
                </div>
                <div id="edit-content-type-wrap">
                    <label class="block text-sm font-semibold mb-1"
                        >Content-Type</label
                    >
                    <input
                        id="edit-content-type"
                        type="text"
                        placeholder="e.g. application/pdf"
                        class="w-full px-3 py-2 rounded-lg bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary"
                    />
                </div>
                <div id="edit-disposition-wrap">
                    <label class="block text-sm font-semibold mb-1"
                        >Content-Disposition</label
                    >
                    <input
                        id="edit-content-disposition"
                        type="text"
                        placeholder='attachment; filename="file.pdf"'
                        class="w-full px-3 py-2 rounded-lg bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary"
                    />
                </div>
                <div id="edit-cache-wrap">
                    <label class="block text-sm font-semibold mb-1"
                        >Cache-Control</label
                    >
                    <input
                        id="edit-cache-control"
                        type="text"
                        placeholder="public, max-age=31536000"
                        class="w-full px-3 py-2 rounded-lg bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary"
                    />
                </div>
                <!-- Dynamic custom metadata pairs -->
                <div>
                    <label class="block text-sm font-semibold mb-2"
                        >Custom Metadata</label
                    >
                    <div id="meta-pairs" class="space-y-2"></div>
                    <button
                        type="button"
                        id="btn-add-meta"
                        class="mt-2 text-sm text-primary font-semibold hover:underline flex items-center gap-1"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-4 h-4"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            ><line x1="12" y1="5" x2="12" y2="19"></line><line
                                x1="5"
                                y1="12"
                                x2="19"
                                y2="12"></line></svg
                        >
                        Add field
                    </button>
                </div>
                <div
                    id="edit-status"
                    class="hidden text-sm text-center py-2 rounded-lg"
                >
                </div>
                <button
                    type="submit"
                    class="w-full bg-primary text-background-dark font-bold py-3 rounded-xl hover:bg-primary/90 transition-all"
                >
                    Save Changes
                </button>
            </form>
        </div>
    </div>

    <!-- ── Delete Confirmation Modal ────────────────────────────── -->
    <div
        id="delete-modal"
        class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm"
    >
        <div
            class="bg-white dark:bg-slate-900 rounded-2xl shadow-2xl w-full max-w-sm p-8 text-center"
        >
            <div
                class="w-14 h-14 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-7 h-7 text-red-500"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    ><polyline points="3 6 5 6 21 6"></polyline><path
                        d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"
                    ></path><path d="M10 11v6"></path><path d="M14 11v6"
                    ></path><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"
                    ></path></svg
                >
            </div>
            <h2 class="text-lg font-bold mb-2">Delete Media?</h2>
            <p id="delete-name" class="text-slate-500 text-sm mb-6 break-all">
            </p>
            <div class="flex gap-3">
                <button
                    id="btn-cancel-delete"
                    class="flex-1 px-4 py-2 rounded-xl border-2 border-slate-200 dark:border-slate-700 font-semibold text-sm hover:bg-slate-50 dark:hover:bg-slate-800 transition-all"
                    >Cancel</button
                >
                <button
                    id="btn-confirm-delete"
                    class="flex-1 px-4 py-2 rounded-xl bg-red-500 hover:bg-red-600 text-white font-bold text-sm transition-all"
                    >Delete</button
                >
            </div>
        </div>
    </div>

    <script>
        (() => {
            // ── State ─────────────────────────────────────────────────
            let allItems: any[] = [];
            let currentTab = "all";
            let pendingDeleteItem: any = null;

            // ── Helpers ───────────────────────────────────────────────
            function formatBytes(bytes: number | null): string {
                if (bytes == null) return "—";
                if (bytes < 1024) return `${bytes} B`;
                if (bytes < 1024 * 1024)
                    return `${(bytes / 1024).toFixed(1)} KB`;
                return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
            }
            function escHtml(s: string) {
                return s
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;");
            }
            function showStatus(el: HTMLElement, msg: string, ok: boolean) {
                el.classList.remove(
                    "hidden",
                    "bg-green-100",
                    "text-green-800",
                    "bg-red-100",
                    "text-red-800",
                );
                el.classList.add(
                    ok ? "bg-green-100" : "bg-red-100",
                    ok ? "text-green-800" : "text-red-800",
                );
                el.textContent = msg;
            }
            function srcLabel(source: string) {
                return source === "cf-images" ? "Cloudflare Images" : "R2";
            }

            // ── Load media ────────────────────────────────────────────
            async function loadMedia() {
                (
                    document.getElementById("loading") as HTMLElement
                ).classList.remove("hidden");
                (document.getElementById("grid") as HTMLElement).classList.add(
                    "hidden",
                );
                (document.getElementById("empty") as HTMLElement).classList.add(
                    "hidden",
                );
                try {
                    const res = await fetch("/api/media/list");
                    const data = (await res.json()) as any;
                    const cfImages = (data.cfImages || []).map((i: any) => ({
                        ...i,
                        source: "cf-images",
                    }));
                    const r2Items = (data.r2 || []).map((i: any) => ({
                        ...i,
                        source: "r2",
                    }));
                    allItems = [...cfImages, ...r2Items];
                    updateStats();
                    renderGrid();
                } catch {
                    (
                        document.getElementById("loading") as HTMLElement
                    ).textContent = "Failed to load media.";
                }
            }

            function updateStats() {
                const cf = allItems.filter(
                    (i) => i.source === "cf-images",
                ).length;
                const r2 = allItems.filter((i) => i.source === "r2").length;
                const totalSize = allItems.reduce(
                    (sum, i) => sum + (i.size || 0),
                    0,
                );
                (
                    document.getElementById("stat-cf") as HTMLElement
                ).textContent = String(cf);
                (
                    document.getElementById("stat-r2") as HTMLElement
                ).textContent = String(r2);
                (
                    document.getElementById("stat-size") as HTMLElement
                ).textContent = formatBytes(totalSize);
            }

            function filtered() {
                const q = (
                    (document.getElementById("search") as HTMLInputElement)
                        .value || ""
                ).toLowerCase();
                return allItems.filter((i) => {
                    const matchTab =
                        currentTab === "all" || i.source === currentTab;
                    const matchQ =
                        !q ||
                        i.name?.toLowerCase().includes(q) ||
                        i.key?.toLowerCase().includes(q);
                    return matchTab && matchQ;
                });
            }

            function renderGrid() {
                const grid = document.getElementById("grid") as HTMLElement;
                const empty = document.getElementById("empty") as HTMLElement;
                const loading = document.getElementById(
                    "loading",
                ) as HTMLElement;
                loading.classList.add("hidden");
                const items = filtered();
                if (items.length === 0) {
                    grid.classList.add("hidden");
                    empty.classList.remove("hidden");
                    return;
                }
                empty.classList.add("hidden");
                grid.classList.remove("hidden");
                grid.innerHTML = items
                    .map((item) => {
                        const name = escHtml(item.name || item.key || item.id);
                        const badge =
                            item.source === "cf-images"
                                ? `<span class="bg-blue-100 text-blue-700 text-[10px] font-bold px-1.5 py-0.5 rounded">CF</span>`
                                : `<span class="bg-orange-100 text-orange-700 text-[10px] font-bold px-1.5 py-0.5 rounded">R2</span>`;
                        const previewHtml =
                            item.source === "cf-images" && item.variants?.[0]
                                ? `<img src="${escHtml(item.variants[0])}" alt="${name}" class="w-full h-32 object-cover" loading="lazy" />`
                                : item.isImage && item.source === "r2"
                                  ? `<div class="w-full h-32 flex items-center justify-center bg-slate-100 dark:bg-slate-800"><svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-slate-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>`
                                  : `<div class="w-full h-32 flex items-center justify-center bg-slate-100 dark:bg-slate-800"><svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-slate-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>`;
                        const encodedId = encodeURIComponent(
                            item.cfId || item.key,
                        );
                        return `<div class="bg-white dark:bg-slate-900 rounded-2xl overflow-hidden border border-slate-100 dark:border-slate-800 hover:shadow-lg hover:-translate-y-1 transition-all group" data-id="${escHtml(item.id)}">
					<div class="relative overflow-hidden">
						${previewHtml}
						<div class="absolute top-2 left-2">${badge}</div>
					</div>
					<div class="p-3">
						<p class="text-xs font-semibold truncate text-slate-800 dark:text-slate-200" title="${name}">${name}</p>
						<p class="text-[10px] text-slate-400 mt-0.5">${escHtml(item.contentType || "")}</p>
						<p class="text-[10px] text-slate-400">${formatBytes(item.size)}</p>
						<div class="flex gap-1 mt-2 opacity-0 group-hover:opacity-100 transition-opacity">
							<button class="btn-edit flex-1 py-1 text-[11px] font-bold bg-primary/10 text-primary hover:bg-primary hover:text-background-dark rounded-lg transition-colors"
								data-item='${escHtml(JSON.stringify(item))}'>Edit</button>
							<button class="btn-delete py-1 px-2 text-[11px] font-bold bg-red-50 text-red-500 hover:bg-red-500 hover:text-white rounded-lg transition-colors"
								data-item='${escHtml(JSON.stringify(item))}'>
								<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
							</button>
						</div>
					</div>
				</div>`;
                    })
                    .join("");

                // Attach edit/delete listeners
                grid.querySelectorAll(".btn-edit").forEach((btn) => {
                    btn.addEventListener("click", () =>
                        openEditModal(
                            JSON.parse((btn as HTMLElement).dataset.item!),
                        ),
                    );
                });
                grid.querySelectorAll(".btn-delete").forEach((btn) => {
                    btn.addEventListener("click", () =>
                        openDeleteModal(
                            JSON.parse((btn as HTMLElement).dataset.item!),
                        ),
                    );
                });
            }

            // ── Tab switching ─────────────────────────────────────────
            document.querySelectorAll(".tab-btn").forEach((btn) => {
                btn.addEventListener("click", () => {
                    currentTab = (btn as HTMLElement).dataset.tab!;
                    document.querySelectorAll(".tab-btn").forEach((b) => {
                        b.classList.remove(
                            "active",
                            "bg-primary",
                            "text-background-dark",
                        );
                        b.classList.add(
                            "bg-slate-100",
                            "dark:bg-slate-800",
                            "text-slate-600",
                            "dark:text-slate-300",
                        );
                    });
                    btn.classList.add("bg-primary", "text-background-dark");
                    btn.classList.remove(
                        "bg-slate-100",
                        "dark:bg-slate-800",
                        "text-slate-600",
                        "dark:text-slate-300",
                    );
                    renderGrid();
                });
            });

            (
                document.getElementById("search") as HTMLInputElement
            ).addEventListener("input", renderGrid);

            // ── Upload Modal ──────────────────────────────────────────
            const uploadModal = document.getElementById(
                "upload-modal",
            ) as HTMLElement;
            const fileInput = document.getElementById(
                "file-input",
            ) as HTMLInputElement;
            const dropZone = document.getElementById(
                "drop-zone",
            ) as HTMLElement;
            const uploadFileList = document.getElementById(
                "upload-file-list",
            ) as HTMLElement;
            let uploadFiles: File[] = [];

            document
                .getElementById("btn-open-upload")!
                .addEventListener("click", () =>
                    uploadModal.classList.remove("hidden"),
                );
            document
                .getElementById("btn-close-upload")!
                .addEventListener("click", () =>
                    uploadModal.classList.add("hidden"),
                );
            uploadModal.addEventListener("click", (e) => {
                if (e.target === uploadModal)
                    uploadModal.classList.add("hidden");
            });

            dropZone.addEventListener("click", () => fileInput.click());
            dropZone.addEventListener("dragover", (e) => {
                e.preventDefault();
                dropZone.classList.add("border-primary");
            });
            dropZone.addEventListener("dragleave", () =>
                dropZone.classList.remove("border-primary"),
            );
            dropZone.addEventListener("drop", (e) => {
                e.preventDefault();
                dropZone.classList.remove("border-primary");
                addFiles(Array.from(e.dataTransfer?.files ?? []));
            });
            fileInput.addEventListener("change", () =>
                addFiles(Array.from(fileInput.files ?? [])),
            );

            function addFiles(files: File[]) {
                uploadFiles = [...uploadFiles, ...files];
                renderFileList();
            }
            function renderFileList() {
                if (uploadFiles.length === 0) {
                    uploadFileList.classList.add("hidden");
                    return;
                }
                uploadFileList.classList.remove("hidden");
                uploadFileList.innerHTML = uploadFiles
                    .map(
                        (f, i) => `
				<div class="flex items-center gap-2 text-sm bg-slate-50 dark:bg-slate-800 rounded-lg px-3 py-2">
					<span class="flex-1 truncate">${escHtml(f.name)}</span>
					<span class="text-slate-400 text-xs">${formatBytes(f.size)}</span>
					<button type="button" class="btn-remove-file text-slate-400 hover:text-red-500" data-index="${i}">×</button>
				</div>`,
                    )
                    .join("");
                uploadFileList
                    .querySelectorAll(".btn-remove-file")
                    .forEach((btn) => {
                        btn.addEventListener("click", () => {
                            uploadFiles.splice(
                                Number((btn as HTMLElement).dataset.index),
                                1,
                            );
                            renderFileList();
                        });
                    });
            }

            (
                document.getElementById("upload-form") as HTMLFormElement
            ).addEventListener("submit", async (e) => {
                e.preventDefault();
                if (uploadFiles.length === 0) return;
                const form = e.target as HTMLFormElement;
                const displayName = (
                    form.querySelector("[name=displayName]") as HTMLInputElement
                ).value;
                const customMetadata = (
                    form.querySelector(
                        "[name=customMetadata]",
                    ) as HTMLTextAreaElement
                ).value;
                const statusEl = document.getElementById(
                    "upload-status",
                ) as HTMLElement;
                const submitBtn = document.getElementById(
                    "btn-upload-submit",
                ) as HTMLButtonElement;

                submitBtn.disabled = true;
                statusEl.classList.remove("hidden");
                showStatus(
                    statusEl,
                    `Uploading ${uploadFiles.length} file(s)…`,
                    true,
                );

                let errors = 0;
                for (const file of uploadFiles) {
                    const fd = new FormData();
                    fd.append("file", file);
                    if (displayName) fd.append("displayName", displayName);
                    if (customMetadata)
                        fd.append("customMetadata", customMetadata);
                    const res = await fetch("/api/media/upload", {
                        method: "POST",
                        body: fd,
                    });
                    const data = (await res.json()) as any;
                    if (!data.ok) errors++;
                }

                if (errors === 0) {
                    showStatus(statusEl, "Upload complete!", true);
                    uploadFiles = [];
                    renderFileList();
                    form.reset();
                    setTimeout(() => {
                        uploadModal.classList.add("hidden");
                        loadMedia();
                    }, 800);
                } else {
                    showStatus(
                        statusEl,
                        `${errors} file(s) failed to upload.`,
                        false,
                    );
                }
                submitBtn.disabled = false;
            });

            // ── Edit Modal ────────────────────────────────────────────
            const editModal = document.getElementById(
                "edit-modal",
            ) as HTMLElement;

            document
                .getElementById("btn-close-edit")!
                .addEventListener("click", () =>
                    editModal.classList.add("hidden"),
                );
            editModal.addEventListener("click", (e) => {
                if (e.target === editModal) editModal.classList.add("hidden");
            });

            function openEditModal(item: any) {
                (document.getElementById("edit-id") as HTMLInputElement).value =
                    item.cfId || item.key;
                (
                    document.getElementById("edit-source") as HTMLInputElement
                ).value = item.source;
                (
                    document.getElementById("edit-name") as HTMLInputElement
                ).value = item.name || "";
                (
                    document.getElementById("edit-source-badge") as HTMLElement
                ).textContent = `Source: ${srcLabel(item.source)}`;

                const isCF = item.source === "cf-images";
                const ctWrap = document.getElementById(
                    "edit-content-type-wrap",
                ) as HTMLElement;
                const dispWrap = document.getElementById(
                    "edit-disposition-wrap",
                ) as HTMLElement;
                const cacheWrap = document.getElementById(
                    "edit-cache-wrap",
                ) as HTMLElement;

                // CF Images doesn't support content-type / disposition / cache-control
                ctWrap.classList.toggle("hidden", isCF);
                dispWrap.classList.toggle("hidden", isCF);
                cacheWrap.classList.toggle("hidden", isCF);

                if (!isCF) {
                    (
                        document.getElementById(
                            "edit-content-type",
                        ) as HTMLInputElement
                    ).value = item.contentType || "";
                    (
                        document.getElementById(
                            "edit-content-disposition",
                        ) as HTMLInputElement
                    ).value = item.contentDisposition || "";
                    (
                        document.getElementById(
                            "edit-cache-control",
                        ) as HTMLInputElement
                    ).value = item.cacheControl || "";
                }

                // Render custom metadata key-value pairs
                const metaPairs = document.getElementById(
                    "meta-pairs",
                ) as HTMLElement;
                const meta = item.customMetadata || item.metadata || {};
                metaPairs.innerHTML = "";
                Object.entries(meta)
                    .filter(([k]) => k !== "displayName")
                    .forEach(([k, v]) => addMetaPair(k, v as string));

                (
                    document.getElementById("edit-status") as HTMLElement
                ).classList.add("hidden");
                editModal.classList.remove("hidden");
            }

            function addMetaPair(key = "", value = "") {
                const metaPairs = document.getElementById(
                    "meta-pairs",
                ) as HTMLElement;
                const row = document.createElement("div");
                row.className = "flex gap-2";
                row.innerHTML = `
				<input type="text" placeholder="Key" value="${escHtml(key)}" class="meta-key flex-1 px-3 py-2 rounded-lg bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
				<input type="text" placeholder="Value" value="${escHtml(value)}" class="meta-val flex-1 px-3 py-2 rounded-lg bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
				<button type="button" class="btn-rm-meta text-slate-400 hover:text-red-500 px-2">×</button>`;
                row.querySelector(".btn-rm-meta")!.addEventListener(
                    "click",
                    () => row.remove(),
                );
                metaPairs.appendChild(row);
            }

            document
                .getElementById("btn-add-meta")!
                .addEventListener("click", () => addMetaPair());

            (
                document.getElementById("edit-form") as HTMLFormElement
            ).addEventListener("submit", async (e) => {
                e.preventDefault();
                const id = (
                    document.getElementById("edit-id") as HTMLInputElement
                ).value;
                const source = (
                    document.getElementById("edit-source") as HTMLInputElement
                ).value as "r2" | "cf-images";
                const displayName = (
                    document.getElementById("edit-name") as HTMLInputElement
                ).value;
                const statusEl = document.getElementById(
                    "edit-status",
                ) as HTMLElement;

                const customMetadata: Record<string, string> = {};
                document
                    .querySelectorAll("#meta-pairs .flex")
                    .forEach((row) => {
                        const k = (
                            row.querySelector(".meta-key") as HTMLInputElement
                        ).value.trim();
                        const v = (
                            row.querySelector(".meta-val") as HTMLInputElement
                        ).value.trim();
                        if (k) customMetadata[k] = v;
                    });

                const body: Record<string, unknown> = {
                    source,
                    id,
                    displayName,
                    customMetadata,
                };
                if (source === "r2") {
                    body.contentType = (
                        document.getElementById(
                            "edit-content-type",
                        ) as HTMLInputElement
                    ).value;
                    body.contentDisposition = (
                        document.getElementById(
                            "edit-content-disposition",
                        ) as HTMLInputElement
                    ).value;
                    body.cacheControl = (
                        document.getElementById(
                            "edit-cache-control",
                        ) as HTMLInputElement
                    ).value;
                }

                statusEl.classList.remove("hidden");
                showStatus(statusEl, "Saving…", true);

                const res = await fetch("/api/media/update", {
                    method: "PATCH",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(body),
                });
                const data = (await res.json()) as any;
                if (data.ok) {
                    showStatus(statusEl, "Saved!", true);
                    setTimeout(() => {
                        editModal.classList.add("hidden");
                        loadMedia();
                    }, 600);
                } else {
                    showStatus(statusEl, `Error: ${data.error}`, false);
                }
            });

            // ── Delete Modal ──────────────────────────────────────────
            const deleteModal = document.getElementById(
                "delete-modal",
            ) as HTMLElement;

            function openDeleteModal(item: any) {
                pendingDeleteItem = item;
                (
                    document.getElementById("delete-name") as HTMLElement
                ).textContent = item.name || item.key || item.id;
                deleteModal.classList.remove("hidden");
            }
            document
                .getElementById("btn-cancel-delete")!
                .addEventListener("click", () =>
                    deleteModal.classList.add("hidden"),
                );
            document
                .getElementById("btn-confirm-delete")!
                .addEventListener("click", async () => {
                    if (!pendingDeleteItem) return;
                    const item = pendingDeleteItem;
                    const id = encodeURIComponent(item.cfId || item.key);
                    await fetch(
                        `/api/media/delete?source=${item.source}&id=${id}`,
                        { method: "DELETE" },
                    );
                    deleteModal.classList.add("hidden");
                    pendingDeleteItem = null;
                    loadMedia();
                });

            // ── Init ──────────────────────────────────────────────────
            loadMedia();
        })();
    </script>
</Layout>
